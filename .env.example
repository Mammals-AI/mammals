# ============================================
# Mammals v1.0 — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.

# ── Owner ──────────────────────────────────
# Your name — used in agent prompts and conversation context.
BOT_OWNER=

# ── Telegram (required) ───────────────────
# Get a bot token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=
# Your Telegram user ID. Send /start to @userinfobot to get it.
ALLOWED_CHAT_ID=
# Optional: a Telegram group ID where the bot can also respond.
# ALLOWED_GROUP_ID=

# ── Claude Code (optional) ────────────────
# Path to the Claude Code CLI binary. Auto-detected if not set.
# CLAUDE_PATH=/usr/local/bin/claude

# ── Voice: Speech-to-Text (optional) ──────
# Get a free API key from console.groq.com
# Enables voice message transcription via Whisper.
# GROQ_API_KEY=

# ── Voice: Text-to-Speech (optional) ──────
# Choose your TTS engine: "voxtral" (local, free) or "elevenlabs" (cloud, paid).
# TTS_ENGINE=voxtral

# Voxtral local TTS (requires running voxtral_server.py)
# VOXTRAL_VOICE=casual_male
# VOXTRAL_TEMPERATURE=1.35
# VOXTRAL_TOP_K=50
# VOXTRAL_TOP_P=0.95

# ElevenLabs cloud TTS (fallback if Voxtral not running)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# ── Video Analysis (optional) ─────────────
# Google AI / Gemini API key for video understanding.
# GOOGLE_API_KEY=

# ── Ports (optional, defaults shown) ──────
# API_PORT=5062
# DASHBOARD_PORT=5075
# VOXTRAL_PORT=5090

# ── Security (optional) ───────────────────
# Bearer token for the HTTP API. If not set, the API is open on localhost.
# CLAUDECLAW_API_TOKEN=
# PIN for HQ dashboard authentication. If not set, no auth required.
# PWA_PIN=

# ── Remote Access (optional) ──────────────
# If using Tailscale, set your machine's Tailscale IP here.
# Used for generating shareable links to dashboards.
# TAILSCALE_IP=

# ── Generation Preferences (optional) ─────
# Preferred engines for AI image/video generation.
# IMAGE_ENGINE=gemini
# VIDEO_ENGINE=veo3
